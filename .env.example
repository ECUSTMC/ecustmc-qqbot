# QQ 机器人配置
QQBOT_APP_ID=your_qqbot_app_id
QQBOT_APP_SECRET=your_qqbot_app_secret

# 高德天气 API
WEATHER_API_TOKEN=your_amap_weather_key

# 黄历 API（聚合数据）
API_APP_ID=your_juhe_app_id
API_APP_SECRET=your_juhe_app_secret

# MC 服务器配置
MC_SERVERS=server1.example.com,server2.example.com
MC_MCSRVSTAT_SERVERS=server1.example.com
MC_SERVER=your_mc_server_host
MC_RCON_PORT=25575
MC_KEY=your_rcon_password

# ECUST AI 配置
ECUST_API_Key=your_ecust_api_key
ECUST_URL=https://your-ecust-api-url/v1/
ECUST_MODEL=MiniMax-M2.5

# Clawdbot 配置
CLAWDBOT_URL=https://your-clawdbot-url/v1/
CLAWDBOT_API_Key=your_clawdbot_api_key

# Ping 测试 API
TJIT_KEY=your_tjit_api_key

# 三角洲行动密码 API
DELTAFORCE_API_TOKEN=your_deltaforce_api_token

# 空教室查询 API
CLASS_API_KEY=your_classroom_api_key

# AI 功能开关
AI_GROUP_ENABLED=false
AI_DIRECT_ENABLED=false

# 飞书配置
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret

# 春节期间运势增强功能开关
SPRING_FESTIVAL_ENABLED=false

# MC整合包投票API配置
MCVOTE_API_URL=https://mcvote.ecustvr.top
MCVOTE_API_TOKEN=your_mcvote_api_token
